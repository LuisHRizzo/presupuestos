// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ImportBatch {
  id        Int       @id @default(autoincrement())
  filename  String
  createdAt DateTime  @default(now())
  status    String    @default("SUCCESS")
  proveedor String?
  products  Product[]
}

model Product {
  id            Int         @id @default(autoincrement())
  codigo        String      @unique
  descripcion   String
  marca         String?
  proveedor     String?     // "BIGDIPPER", "HIKVISION", "ACUBOX", "GENERICO"
  precioPartner Float?
  precioGremio  Float?
  precioPmp     Float?
  iva           Float?
  stockTotal    Int         @default(0)

  importBatchId Int
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id])
  kitItems      KitItem[]
}

// Ítems de servicio (horas de soporte, ingeniería, jornadas de instalación)
model ServiceItem {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique
  descripcion String
  tipo        String    // "HORAS_SOPORTE", "INGENIERIA", "JORNADA_INSTALACION"
  precio      Float
  unidad      String    // "hora", "jornada", "media jornada"
  activo      Boolean   @default(true)
  kitItems    KitItem[]
}

// Kits de productos y servicios agrupados
model Kit {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  descripcion String?
  activo      Boolean   @default(true)
  items       KitItem[]
}

model KitItem {
  id        Int          @id @default(autoincrement())
  kitId     Int
  kit       Kit          @relation(fields: [kitId], references: [id], onDelete: Cascade)
  productId Int?
  product   Product?     @relation(fields: [productId], references: [id])
  serviceId Int?
  service   ServiceItem? @relation(fields: [serviceId], references: [id])
  cantidad  Int          @default(1)
}
