# ─────────────────────────────────────────────────────────
# .env — Variables para docker compose
# COPIAR como .env y completar los valores antes de levantar
# ─────────────────────────────────────────────────────────

# API Key de Google Gemini (opcional — sin esto usa contenido de fallback)
GEMINI_API_KEY=

# Secreto para firmar los JWT de sesión (CAMBIAR en producción — mínimo 32 caracteres)
JWT_SECRET=cambiar-por-un-secreto-largo-y-aleatorio-en-produccion
